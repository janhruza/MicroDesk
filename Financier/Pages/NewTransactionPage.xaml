<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Financier.Pages.NewTransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Financier.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Tag="New Transaction">

    <Grid Padding="24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="tbTitle" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold"/>

        <!-- Form Card -->
        <Border Grid.Row="1" 
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="32"
                CornerRadius="12"
                VerticalAlignment="Top"
                MaxWidth="500"
                HorizontalAlignment="Stretch">
            
            <StackPanel Spacing="20">
                <CalendarDatePicker Name="dpDate"
                                    Header="Date"
                                    HorizontalAlignment="Stretch"
                                    FirstDayOfWeek="Monday"/>

                <ComboBox Name="cbxCategory"
                          Header="Category"
                          HorizontalAlignment="Stretch"/>

                <NumberBox Name="txtValue"
                           Header="Amount"
                           Value="0"
                           SpinButtonPlacementMode="Compact"
                           HorizontalAlignment="Stretch"/>

                <TextBox Name="txtNote"
                         Header="Note (Optional)"
                         PlaceholderText="Add a description..."
                         AcceptsReturn="True"
                         MinHeight="100"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <Button x:Name="btnSave" 
                    Content="Save Transaction" 
                    Style="{ThemeResource AccentButtonStyle}"
                    Padding="24,8"
                    Click="btnSave_Click"/>
            
            <Button x:Name="btnClear" 
                    Content="Clear" 
                    Padding="24,8"
                    Click="btnClear_Click"/>
        </StackPanel>
    </Grid>
</Page>
