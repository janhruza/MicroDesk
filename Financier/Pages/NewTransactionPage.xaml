<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Financier.Pages.NewTransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Financier.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Tag="New Transaction"> <!-- Overwritten in code based on the transaction type -->

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0"
                    OverflowButtonVisibility="Collapsed">
            
            <AppBarButton Icon="Clear"
                          Label="Clear"
                          Name="btnClear"
                          ToolTipService.Placement="Mouse"
                          ToolTipService.ToolTip="Clear fields"
                          Click="btnClear_Click"/>
            
            <AppBarButton Icon="Save"
                          Label="Save"
                          Name="btnSave"
                          ToolTipService.Placement="Mouse"
                          ToolTipService.ToolTip="Save"
                          Click="btnSave_Click"/>
        </CommandBar>

        <StackPanel Grid.Row="1">

            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="Category"
                       Margin="0,0,0,8"/>

            <ComboBox Name="cbxCategory"
                      HorizontalAlignment="Stretch"/>

            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="Value"
                       Margin="0,8,0,8"/>

            <TextBox Name="txtValue"/>

            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="Note"
                       Margin="0,8,0,8"/>

            <TextBox AcceptsReturn="True"
                     Name="txtNote"/>

        </StackPanel>
        
    </Grid>
</Page>
