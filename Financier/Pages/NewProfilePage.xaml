<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Financier.Pages.NewProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Financier.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Tag="New Profile">

    <Grid Padding="24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create New Profile" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold"/>

        <InfoBar Grid.Row="1"
                 Name="ib"
                 IsOpen="True"
                 Severity="Informational"
                 Title="Local Storage"
                 Message="Your data will be stored locally on this machine."/>

        <Border Grid.Row="2" 
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="32"
                CornerRadius="12"
                VerticalAlignment="Top"
                MaxWidth="500"
                HorizontalAlignment="Left">
            
            <StackPanel Spacing="20">
                <TextBox Name="txtName"
                         Header="Profile Name"
                         PlaceholderText="Enter a name for this profile..."
                         HorizontalAlignment="Stretch"/>
                
                <TextBlock Text="This name will be used to identify your data files." 
                           Style="{ThemeResource CaptionTextBlockStyle}" 
                           Opacity="0.6" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <Button x:Name="btnSave" 
                    Content="Create Profile" 
                    Style="{ThemeResource AccentButtonStyle}"
                    Padding="24,8"
                    Click="btnSave_Click"/>
            
            <Button x:Name="btnClear" 
                    Content="Clear" 
                    Padding="24,8"
                    Click="btnClear_Click"/>

            <Button x:Name="btnSwitchProfiles" 
                    Content="Cancel" 
                    Padding="24,8"
                    Click="btnSwitchProfiles_Click"/>
        </StackPanel>
    </Grid>
</Page>
