<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Financier.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Financier"
    xmlns:core="using:Financier.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Financier">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <Grid.RowDefinitions>

            <!--Caption bar row-->
            <RowDefinition Height="Auto"/>
            
            <!--Content row-->
            <RowDefinition />

        </Grid.RowDefinitions>

        <!--Title bar-->
        <TitleBar Grid.Row="0"
                  Name="titleBar"
                  Title="Financier"
                  IsPaneToggleButtonVisible="True"
                  PaneToggleRequested="titleBar_PaneToggleRequested"/>

        <!--Navigation bar-->
        <NavigationView Grid.Row="1"
                        Name="nav"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="nav_SelectionChanged">

            <!--Navigation options-->
            <NavigationView.MenuItems>

                <!--Dashboard tab-->
                <NavigationViewItem Content="Dashboard"
                                    Icon="Home"
                                    Tag="home"
                                    IsSelected="True"/>

                <!--Expanses tab-->
                <NavigationViewItem Content="Expanses"
                                    Icon="Remove"
                                    Tag="expanses"/>

                <!--Incomes tab-->
                <NavigationViewItem Content="Incomes"
                                    Icon="Add"
                                    Tag="incomes"/>

            </NavigationView.MenuItems>

            <!--Frame to display pages-->
            <Frame Name="frm"
                   Margin="16"
                   Navigated="frm_Navigated"/>

        </NavigationView>

    </Grid>
</Window>
