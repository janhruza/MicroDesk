<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Focus.Pages.PgNewSession"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Focus.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Tag="New Session">

    <Page.ContextFlyout>
        <MenuFlyout>
            <MenuFlyoutItem Text="Reset to default"/>
        </MenuFlyout>
    </Page.ContextFlyout>

    <StackPanel>
        
        <!--New session page-->
        <TimePicker Header="Enter target time"
                    SelectedTime="00:15"
                    Name="tp"
                    HorizontalAlignment="Stretch"
                    MinuteIncrement="5"
                    TimeChanged="tp_TimeChanged"/>

        <CheckBox Content="Include breaks"
                  IsChecked="True"
                  Name="cbIncludeBreaks"
                  Click="cbIncludeBreaks_Click"/>

        <TextBlock Text="Ready to start"
                   Margin="0,16,0,0"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Name="tbInfo"/>

        <Grid ColumnSpacing="16"
              Margin="0,16,0,0">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button Content="Clear"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Name="btnClear"
                    Click="btnClear_Click"/>
            
            <Button Content="Start"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Name="btnStart"/>
        </Grid>

    </StackPanel>
</Page>
